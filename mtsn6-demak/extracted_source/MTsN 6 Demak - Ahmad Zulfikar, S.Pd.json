{"files":[{"id":"e103236e-f98b-4ef9-a902-5d7fdecee26a","name":"appsscript","type":"json","source":"{\n  \"timeZone\": \"Asia/Jakarta\",\n  \"dependencies\": {},\n  \"exceptionLogging\": \"STACKDRIVER\",\n  \"runtimeVersion\": \"V8\",\n  \"webapp\": {\n    \"executeAs\": \"USER_DEPLOYING\",\n    \"access\": \"ANYONE_ANONYMOUS\"\n  }\n}"},{"id":"ddcfbb66-6e0d-4688-822f-b1cd05d40a0a","name":"Kode","type":"server_js","source":"function doGet() {\n  return HtmlService.createHtmlOutputFromFile(\u0027Index\u0027)\n    .setTitle(\u0027MTsN 6 Demak - Ahmad Zulfikar, S.Pd\u0027)\n    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);\n}"},{"id":"76c95b5b-c480-4e75-b15b-d9ee7a8a4cc9","name":"Index","type":"html","source":"\u003c!DOCTYPE html\u003e\n\u003chtml lang\u003d\"id\" class\u003d\"scroll-smooth\"\u003e\n\u003chead\u003e\n    \u003cmeta charset\u003d\"UTF-8\"\u003e\n    \u003cmeta name\u003d\"viewport\" content\u003d\"width\u003ddevice-width, initial-scale\u003d1.0\"\u003e\n    \u003ctitle\u003eAhmad Zulfikar, S.Pd. - Belajar Online\u003c/title\u003e\n    \n    \u003c!-- Tailwind CSS --\u003e\n    \u003cscript src\u003d\"https://cdn.tailwindcss.com\"\u003e\u003c/script\u003e\n    \n    \u003c!-- Font Awesome untuk Ikon --\u003e\n    \u003clink rel\u003d\"stylesheet\" href\u003d\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\"\u003e\n    \n    \u003c!-- Google Fonts --\u003e\n    \u003clink href\u003d\"https://fonts.googleapis.com/css2?family\u003dInter:wght@300;400;500;600\u0026family\u003dPlus+Jakarta+Sans:wght@500;600;700;800\u0026family\u003dAmiri:wght@400;700\u0026display\u003dswap\" rel\u003d\"stylesheet\"\u003e\n    \n    \u003cscript\u003e\n        tailwind.config \u003d {\n            theme: {\n                extend: {\n                    fontFamily: {\n                        sans: [\u0027Inter\u0027, \u0027sans-serif\u0027],\n                        heading: [\u0027Plus Jakarta Sans\u0027, \u0027sans-serif\u0027],\n                        arabic: [\u0027Amiri\u0027, \u0027serif\u0027],\n                    },\n                    colors: {\n                        teal: {\n                            850: \u0027#0f5d56\u0027,\n                            900: \u0027#134e4a\u0027,\n                            950: \u0027#042f2e\u0027,\n                        }\n                    }\n                }\n            }\n        }\n    \u003c/script\u003e\n    \n    \u003cstyle\u003e\n        body {\n            background-color: #f8fafc; /* Slate 50 */\n            color: #334155; /* Slate 700 */\n            /* Animasi Fade-in saat halaman dimuat */\n            animation: fadeInPage 0.4s ease-out forwards;\n        }\n        \n        /* Custom Scrollbar */\n        ::-webkit-scrollbar { width: 8px; }\n        ::-webkit-scrollbar-track { background: #f1f5f9; }\n        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }\n        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }\n\n        /* Islamic Pattern Overlay */\n        .pattern-bg {\n            background-image: url(\"data:image/svg+xml,%3Csvg width\u003d\u002760\u0027 height\u003d\u002760\u0027 viewBox\u003d\u00270 0 60 60\u0027 xmlns\u003d\u0027http://www.w3.org/2000/svg\u0027%3E%3Cg fill\u003d\u0027none\u0027 fill-rule\u003d\u0027evenodd\u0027%3E%3Cg fill\u003d\u0027%23ffffff\u0027 fill-opacity\u003d\u00270.05\u0027%3E%3Cpath d\u003d\u0027M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\u0027/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n        }\n\n        /* Animations */\n        .fade-in {\n            animation: fadeIn 0.8s ease-out forwards;\n            opacity: 0;\n            transform: translateY(20px);\n        }\n        .delay-100 { animation-delay: 0.1s; }\n        .delay-200 { animation-delay: 0.2s; }\n        .delay-300 { animation-delay: 0.3s; }\n        .delay-400 { animation-delay: 0.4s; }\n\n        @keyframes fadeIn { \n            to { opacity: 1; transform: translateY(0); } \n        }\n\n        @keyframes fadeInPage {\n            0% { opacity: 0; }\n            100% { opacity: 1; }\n        }\n\n        /* Class khusus untuk transisi keluar (Fade-out) */\n        .page-transitioning {\n            opacity: 0 !important;\n            transition: opacity 0.3s ease-out !important;\n        }\n\n        /* Card Hover Effects */\n        .hover-card {\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n        .hover-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 12px 20px -8px rgba(0, 0, 0, 0.1);\n        }\n    \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody class\u003d\"font-sans antialiased selection:bg-teal-200 selection:text-teal-900 overflow-x-hidden\"\u003e\n\n    \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d NAVBAR \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n    \u003cnav class\u003d\"fixed w-full z-50 transition-all duration-300 bg-white/90 backdrop-blur-md border-b border-slate-200/50 shadow-sm\"\u003e\n        \u003cdiv class\u003d\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"\u003e\n            \u003cdiv class\u003d\"flex justify-between items-center h-16\"\u003e\n                \u003c!-- Logo/Brand --\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/\" target\u003d\"_top\" class\u003d\"flex items-center gap-3 hover:opacity-80 transition-opacity\"\u003e\n                    \u003cdiv class\u003d\"w-8 h-8 rounded-lg bg-teal-600 flex items-center justify-center text-white\"\u003e\n                        \u003ci class\u003d\"fa-solid fa-book-open text-sm\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                    \u003cspan class\u003d\"font-heading font-bold text-lg tracking-wide text-slate-800\"\u003eBelajar\u003cspan class\u003d\"text-teal-600\"\u003eOnline\u003c/span\u003e\u003c/span\u003e\n                \u003c/a\u003e\n\n                \u003c!-- Desktop Menu --\u003e\n                \u003cdiv class\u003d\"hidden md:flex items-center space-x-8\"\u003e\n                    \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/fiqih\" target\u003d\"_top\" class\u003d\"text-sm font-medium text-slate-600 hover:text-teal-600 transition-colors\"\u003e\n                        Materi Fiqih\n                    \u003c/a\u003e\n                    \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/IPA\" target\u003d\"_top\" class\u003d\"text-sm font-medium text-slate-600 hover:text-teal-600 transition-colors\"\u003e\n                        Materi IPA\n                    \u003c/a\u003e\n                    \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/formatif\" target\u003d\"_top\" class\u003d\"text-sm font-medium text-slate-600 hover:text-teal-600 transition-colors\"\u003e\n                        Uji Kompetensi\n                    \u003c/a\u003e\n                    \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/nilai-siswa\" target\u003d\"_top\" class\u003d\"text-sm font-medium text-slate-600 hover:text-teal-600 transition-colors\"\u003e\n                        Rekap Nilai\n                    \u003c/a\u003e\n                \u003c/div\u003e\n\n                \u003c!-- Mobile Menu Button --\u003e\n                \u003cdiv class\u003d\"md:hidden flex items-center\"\u003e\n                    \u003cbutton onclick\u003d\"document.getElementById(\u0027mobile-menu\u0027).classList.toggle(\u0027hidden\u0027)\" class\u003d\"text-slate-600 hover:text-teal-600 focus:outline-none p-2\"\u003e\n                        \u003ci class\u003d\"fa-solid fa-bars text-xl\"\u003e\u003c/i\u003e\n                    \u003c/button\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n\n        \u003c!-- Mobile Menu (Hidden by default) --\u003e\n        \u003cdiv id\u003d\"mobile-menu\" class\u003d\"hidden md:hidden bg-white border-t border-slate-100 shadow-lg absolute w-full\"\u003e\n            \u003cdiv class\u003d\"px-4 pt-4 pb-6 space-y-2\"\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/fiqih\" target\u003d\"_top\" class\u003d\"block px-3 py-3 rounded-md text-base font-medium text-slate-700 hover:text-teal-600 hover:bg-teal-50 transition-colors\"\u003eMateri Fiqih\u003c/a\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/IPA\" target\u003d\"_top\" class\u003d\"block px-3 py-3 rounded-md text-base font-medium text-slate-700 hover:text-teal-600 hover:bg-teal-50 transition-colors\"\u003eMateri IPA\u003c/a\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/formatif\" target\u003d\"_top\" class\u003d\"block px-3 py-3 rounded-md text-base font-medium text-slate-700 hover:text-teal-600 hover:bg-teal-50 transition-colors\"\u003eUji Kompetensi\u003c/a\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/nilai-siswa\" target\u003d\"_top\" class\u003d\"block px-3 py-3 rounded-md text-base font-medium text-slate-700 hover:text-teal-600 hover:bg-teal-50 transition-colors\"\u003eRekap Nilai\u003c/a\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/nav\u003e\n\n    \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d HERO SECTION \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n    \u003csection id\u003d\"beranda\" class\u003d\"relative pt-28 pb-20 lg:pt-36 lg:pb-32 bg-teal-900 pattern-bg overflow-hidden border-b border-teal-800\"\u003e\n        \u003cdiv class\u003d\"absolute inset-0 bg-gradient-to-b from-teal-950/80 to-teal-900/95\"\u003e\u003c/div\u003e\n        \n        \u003c!-- Decorative Elements --\u003e\n        \u003cdiv class\u003d\"absolute top-20 right-10 w-64 h-64 bg-teal-500 opacity-20 rounded-full blur-3xl\"\u003e\u003c/div\u003e\n        \u003cdiv class\u003d\"absolute bottom-10 left-10 w-48 h-48 bg-amber-400 opacity-10 rounded-full blur-3xl\"\u003e\u003c/div\u003e\n\n        \u003cdiv class\u003d\"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center md:text-left\"\u003e\n            \u003cdiv class\u003d\"flex flex-col md:flex-row items-center gap-10 lg:gap-16\"\u003e\n                \n                \u003c!-- Profile Image --\u003e\n                \u003cdiv class\u003d\"flex-shrink-0 relative group fade-in\"\u003e\n                    \u003cdiv class\u003d\"absolute -inset-3 bg-gradient-to-tr from-amber-400 to-teal-300 rounded-full blur-lg opacity-30 group-hover:opacity-60 transition duration-500\"\u003e\u003c/div\u003e\n                    \u003cimg src\u003d\"https://github.com/ahmdd-zulfikar/ahmdd-zulfikar.github.io/blob/main/foto-profil.jpg?raw\u003dtrue\" \n                         onerror\u003d\"this.src\u003d\u0027https://ui-avatars.com/api/?name\u003dAhmad+Zulfikar\u0026background\u003d0f766e\u0026color\u003dfff\u0026size\u003d256\u0027\"\n                         alt\u003d\"Ahmad Zulfikar\" \n                         class\u003d\"relative w-40 h-40 md:w-56 md:h-56 lg:w-64 lg:h-64 rounded-full border-4 border-white/20 shadow-2xl object-cover bg-white\"\u003e\n                \u003c/div\u003e\n\n                \u003c!-- Text Content --\u003e\n                \u003cdiv class\u003d\"flex-1 fade-in delay-100\"\u003e\n                    \u003cp class\u003d\"font-arabic text-2xl lg:text-3xl text-teal-100/90 mb-4 tracking-wider text-center md:text-left\"\u003eبِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ\u003c/p\u003e\n                    \u003ch1 class\u003d\"text-4xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-tight font-heading mb-4 flex items-center justify-center md:justify-start flex-wrap\"\u003e\n                        Ahmad Zulfikar\n                        \u003cspan class\u003d\"text-teal-400 text-2xl md:text-4xl\"\u003e, S.Pd.\u003c/span\u003e\u003cspan class\u003d\"relative inline-flex items-center justify-center ml-2 mr-1\" title\u003d\"Akun Terverifikasi\"\u003e\n                            \u003ci class\u003d\"fa-solid fa-certificate text-blue-500 text-2xl md:text-3xl lg:text-4xl drop-shadow-md\"\u003e\u003c/i\u003e\n                            \u003ci class\u003d\"fa-solid fa-check text-white absolute text-xs md:text-sm lg:text-base\"\u003e\u003c/i\u003e\n                        \u003c/span\u003e\n                    \u003c/h1\u003e\n                    \u003cp class\u003d\"text-lg md:text-xl text-teal-50 flex items-center justify-center md:justify-start gap-2 mb-6\"\u003e\n                        \u003ci class\u003d\"fa-solid fa-chalkboard-user text-amber-400\"\u003e\u003c/i\u003e Guru Mapel Agama\n                    \u003c/p\u003e\n                    \u003cp class\u003d\"text-teal-100/80 max-w-2xl text-sm md:text-base leading-relaxed border-l-4 border-amber-400 pl-4 mx-auto md:mx-0\"\u003e\n                        \"Pendidikan bukan sekadar mentransfer ilmu, melainkan menanamkan adab dan menginspirasi akhlak. Dedikasi penuh untuk membimbing generasi penerus dalam proses pembelajaran bermakna.\"\n                    \u003c/p\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/section\u003e\n\n    \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d BAGIAN FITUR E-LEARNING \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n    \u003csection id\u003d\"fitur-digital\" class\u003d\"py-16 md:py-24 bg-white relative overflow-hidden\"\u003e\n        \u003cdiv class\u003d\"absolute top-0 right-0 w-64 h-64 bg-teal-50 rounded-full blur-3xl opacity-50 -translate-y-1/2 translate-x-1/3\"\u003e\u003c/div\u003e\n        \n        \u003cdiv class\u003d\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10\"\u003e\n            \n            \u003cdiv class\u003d\"max-w-4xl mb-16 fade-in\"\u003e\n                \u003cdiv class\u003d\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-teal-50 text-teal-600 text-sm font-bold mb-5 border border-teal-100 tracking-wide\"\u003e\n                    \u003ci class\u003d\"fa-solid fa-rocket text-amber-500\"\u003e\u003c/i\u003e EKOSISTEM DIGITAL\n                \u003c/div\u003e\n                \u003cp class\u003d\"text-xl md:text-2xl text-slate-700 leading-relaxed font-light font-heading\"\u003e\n                    Transformasi pendidikan di era digital memberikan ruang tanpa batas untuk bereksplorasi. Melalui \u003cstrong class\u003d\"font-bold text-teal-700\"\u003eE-Learning\u003c/strong\u003e, proses belajar menjadi lebih interaktif, fleksibel, dan terukur.\n                \u003c/p\u003e\n            \u003c/div\u003e\n\n            \u003cdiv class\u003d\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8\"\u003e\n                \n                \u003cdiv class\u003d\"group p-8 rounded-[2rem] bg-slate-50 border border-slate-100 hover:border-teal-300 hover:bg-white hover:shadow-xl hover:shadow-teal-900/5 transition-all duration-300 hover:-translate-y-2 text-center fade-in delay-100\"\u003e\n                    \u003cdiv class\u003d\"w-20 h-20 mx-auto bg-gradient-to-br from-teal-100 to-teal-50 text-teal-600 rounded-2xl flex items-center justify-center text-4xl mb-6 group-hover:scale-110 transition-transform duration-500 shadow-sm relative\"\u003e\n                        \u003cdiv class\u003d\"absolute inset-0 bg-teal-400 opacity-0 group-hover:opacity-20 rounded-2xl transition-opacity duration-500 blur-md\"\u003e\u003c/div\u003e\n                        \u003ci class\u003d\"fa-solid fa-laptop-file relative z-10 group-hover:-rotate-3 transition-transform\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                    \u003ch3 class\u003d\"font-bold text-lg text-slate-800 mb-3 font-heading group-hover:text-teal-700 transition-colors\"\u003eMateri Terpadu\u003c/h3\u003e\n                    \u003cp class\u003d\"text-sm text-slate-500 leading-relaxed\"\u003eModul pembelajaran, presentasi, dan referensi materi tersusun secara sistematis.\u003c/p\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class\u003d\"group p-8 rounded-[2rem] bg-slate-50 border border-slate-100 hover:border-blue-300 hover:bg-white hover:shadow-xl hover:shadow-blue-900/5 transition-all duration-300 hover:-translate-y-2 text-center fade-in delay-200\"\u003e\n                    \u003cdiv class\u003d\"w-20 h-20 mx-auto bg-gradient-to-br from-blue-100 to-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-4xl mb-6 group-hover:scale-110 transition-transform duration-500 shadow-sm relative\"\u003e\n                        \u003cdiv class\u003d\"absolute inset-0 bg-blue-400 opacity-0 group-hover:opacity-20 rounded-2xl transition-opacity duration-500 blur-md\"\u003e\u003c/div\u003e\n                        \u003ci class\u003d\"fa-solid fa-shapes relative z-10 group-hover:rotate-12 transition-transform\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                    \u003ch3 class\u003d\"font-bold text-lg text-slate-800 mb-3 font-heading group-hover:text-blue-700 transition-colors\"\u003eBelajar Interaktif\u003c/h3\u003e\n                    \u003cp class\u003d\"text-sm text-slate-500 leading-relaxed\"\u003ePengalaman belajar yang menyenangkan didukung dengan media visual dan penugasan kreatif.\u003c/p\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class\u003d\"group p-8 rounded-[2rem] bg-slate-50 border border-slate-100 hover:border-amber-300 hover:bg-white hover:shadow-xl hover:shadow-amber-900/5 transition-all duration-300 hover:-translate-y-2 text-center fade-in delay-300\"\u003e\n                    \u003cdiv class\u003d\"w-20 h-20 mx-auto bg-gradient-to-br from-amber-100 to-amber-50 text-amber-600 rounded-2xl flex items-center justify-center text-4xl mb-6 group-hover:scale-110 transition-transform duration-500 shadow-sm relative\"\u003e\n                        \u003cdiv class\u003d\"absolute inset-0 bg-amber-400 opacity-0 group-hover:opacity-20 rounded-2xl transition-opacity duration-500 blur-md\"\u003e\u003c/div\u003e\n                        \u003ci class\u003d\"fa-solid fa-list-check relative z-10 group-hover:-rotate-3 transition-transform\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                    \u003ch3 class\u003d\"font-bold text-lg text-slate-800 mb-3 font-heading group-hover:text-amber-700 transition-colors\"\u003eEvaluasi Digital\u003c/h3\u003e\n                    \u003cp class\u003d\"text-sm text-slate-500 leading-relaxed\"\u003eUji pemahaman melalui kuis formatif dan latihan soal yang interaktif serta mandiri.\u003c/p\u003e\n                \u003c/div\u003e\n                \n                \u003cdiv class\u003d\"group p-8 rounded-[2rem] bg-slate-50 border border-slate-100 hover:border-orange-300 hover:bg-white hover:shadow-xl hover:shadow-orange-900/5 transition-all duration-300 hover:-translate-y-2 text-center fade-in delay-400\"\u003e\n                    \u003cdiv class\u003d\"w-20 h-20 mx-auto bg-gradient-to-br from-orange-100 to-orange-50 text-orange-600 rounded-2xl flex items-center justify-center text-4xl mb-6 group-hover:scale-110 transition-transform duration-500 shadow-sm relative\"\u003e\n                        \u003cdiv class\u003d\"absolute inset-0 bg-orange-400 opacity-0 group-hover:opacity-20 rounded-2xl transition-opacity duration-500 blur-md\"\u003e\u003c/div\u003e\n                        \u003ci class\u003d\"fa-solid fa-chart-pie relative z-10 group-hover:rotate-3 transition-transform\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                    \u003ch3 class\u003d\"font-bold text-lg text-slate-800 mb-3 font-heading group-hover:text-orange-700 transition-colors\"\u003eAnalisis Capaian\u003c/h3\u003e\n                    \u003cp class\u003d\"text-sm text-slate-500 leading-relaxed\"\u003ePantau perkembangan dan rekapitulasi nilai secara otomatis dan transparan.\u003c/p\u003e\n                \u003c/div\u003e\n\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/section\u003e\n\n    \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d FOOTER \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n    \u003cfooter class\u003d\"bg-teal-950 text-teal-200 py-10 border-t border-teal-900\"\u003e\n        \u003cdiv class\u003d\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center\"\u003e\n            \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/\" target\u003d\"_top\" class\u003d\"inline-flex items-center justify-center gap-3 mb-4 text-white hover:opacity-80 transition-opacity\"\u003e\n                \u003ci class\u003d\"fa-solid fa-book-open text-xl text-teal-500\"\u003e\u003c/i\u003e\n                \u003cspan class\u003d\"font-heading font-bold text-xl tracking-wide\"\u003eBelajar\u003cspan class\u003d\"text-teal-500\"\u003eOnline\u003c/span\u003e\u003c/span\u003e\n            \u003c/a\u003e\n            \u003cp class\u003d\"text-sm text-teal-400/80 max-w-md mx-auto mb-8\"\u003e\n                Belajar Online adalah Sistem Pembelajaran Berbasis Digital untuk Memudahkan Guru dan Murid dalam Mencapai Tujuan Pembelajaran.\n            \u003c/p\u003e\n            \u003cdiv class\u003d\"pt-6 border-t border-teal-900/50 text-xs text-teal-500\"\u003e\n                \u003cp\u003e\u0026copy; 2026 Ahmad Zulfikar, S.Pd.\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/footer\u003e\n\n    \u003c!-- Skrip Transisi Halaman (Mencegah Blank Abu-abu saat Pindah) --\u003e\n    \u003cscript\u003e\n        document.addEventListener(\u0027DOMContentLoaded\u0027, () \u003d\u003e {\n            const links \u003d document.querySelectorAll(\u0027a[href]\u0027);\n            \n            links.forEach(link \u003d\u003e {\n                link.addEventListener(\u0027click\u0027, function(e) {\n                    const href \u003d this.getAttribute(\u0027href\u0027);\n                    \n                    // Abaikan script jika link adalah anchor (halaman yang sama), tidak ada href, atau target blank\n                    if (!href || href.startsWith(\u0027#\u0027) || this.target \u003d\u003d\u003d \u0027_blank\u0027) return;\n                    \n                    // Tahan perilaku bawaan link\n                    e.preventDefault();\n                    \n                    const targetUrl \u003d this.href;\n                    const targetAttr \u003d this.target;\n\n                    // Tambahkan class page-transitioning untuk memulai animasi fade out\n                    document.body.classList.add(\u0027page-transitioning\u0027);\n\n                    // Pindah halaman setelah animasi fade out selesai (300ms)\n                    setTimeout(() \u003d\u003e {\n                        if (targetAttr \u003d\u003d\u003d \u0027_top\u0027) {\n                            window.top.location.href \u003d targetUrl;\n                        } else {\n                            window.location.href \u003d targetUrl;\n                        }\n                    }, 300);\n                });\n            });\n        });\n\n        // Menangani BFCache (Mencegah layar tetap putih jika user menekan tombol Back di browser)\n        window.addEventListener(\u0027pageshow\u0027, (event) \u003d\u003e {\n            if (event.persisted || document.body.classList.contains(\u0027page-transitioning\u0027)) {\n                document.body.classList.remove(\u0027page-transitioning\u0027);\n            }\n        });\n    \u003c/script\u003e\n\n\u003c/body\u003e\n\u003c/html\u003e"}]}