\n                        \u003ci class\u003d\"fas fa-chevron-right text-slate-300 group-hover:text-amber-500 text-xs transition-colors\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                \u003c/a\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003c!-- JavaScript Logic --\u003e\n    \u003cscript\u003e\n        function closeModal(modalId) {\n            document.getElementById(modalId).classList.add(\u0027hidden\u0027);\n        }\n\n        const comingSoonModal \u003d document.getElementById(\u0027comingSoonModal\u0027);\n        const modalTopic \u003d document.getElementById(\u0027modalTopic\u0027);\n\n        function showComingSoon(topicName) {\n            modalTopic.textContent \u003d topicName;\n            comingSoonModal.classList.remove(\u0027hidden\u0027);\n        }\n\n        const selectionModal \u003d document.getElementById(\u0027selectionModal\u0027);\n        function openSelectionModal() {\n            selectionModal.classList.remove(\u0027hidden\u0027);\n        }\n\n        const jamaQasarModal \u003d document.getElementById(\u0027jamaQasarModal\u0027);\n        function openJamaQasarModal() {\n            jamaQasarModal.classList.remove(\u0027hidden\u0027);\n        }\n\n        const daruratModal \u003d document.getElementById(\u0027daruratModal\u0027);\n        function openDaruratModal() {\n            daruratModal.classList.remove(\u0027hidden\u0027);\n        }\n\n        window.onclick \u003d function(event) {\n            if (event.target \u003d\u003d\u003d comingSoonModal) closeModal(\u0027comingSoonModal\u0027);\n            if (event.target \u003d\u003d\u003d selectionModal) closeModal(\u0027selectionModal\u0027);\n            if (event.target \u003d\u003d\u003d jamaQasarModal) closeModal(\u0027jamaQasarModal\u0027);\n            if (event.target \u003d\u003d\u003d daruratModal) closeModal(\u0027daruratModal\u0027);\n        }\n\n        document.addEventListener(\u0027keydown\u0027, function(event) {\n            if (event.key \u003d\u003d\u003d \u0027Escape\u0027) {\n                closeModal(\u0027comingSoonModal\u0027);\n                closeModal(\u0027selectionModal\u0027);\n                closeModal(\u0027jamaQasarModal\u0027);\n                closeModal(\u0027daruratModal\u0027);\n            }\n        });\n    \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e"}]}