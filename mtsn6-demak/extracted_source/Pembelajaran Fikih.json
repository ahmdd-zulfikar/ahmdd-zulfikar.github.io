{"files":[{"id":"2f1036c0-d9fc-4cfe-ab87-659deb2f2919","name":"appsscript","type":"json","source":"{\n  \"timeZone\": \"Asia/Jakarta\",\n  \"dependencies\": {},\n  \"exceptionLogging\": \"STACKDRIVER\",\n  \"runtimeVersion\": \"V8\",\n  \"webapp\": {\n    \"executeAs\": \"USER_DEPLOYING\",\n    \"access\": \"ANYONE_ANONYMOUS\"\n  }\n}"},{"id":"6a7c61d9-4e64-487b-875b-42694beeab70","name":"Kode","type":"server_js","source":"function doGet() {\n  return HtmlService.createHtmlOutputFromFile(\u0027Index\u0027)\n    .setTitle(\u0027Fikih\u0027)\n    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);\n}"},{"id":"2f732bb3-13c3-4664-895f-62ee985023c4","name":"Index","type":"html","source":"\u003c!DOCTYPE html\u003e\n\u003chtml lang\u003d\"id\" class\u003d\"scroll-smooth\"\u003e\n\u003chead\u003e\n    \u003cmeta charset\u003d\"UTF-8\"\u003e\n    \u003cmeta name\u003d\"viewport\" content\u003d\"width\u003ddevice-width, initial-scale\u003d1.0\"\u003e\n    \u003ctitle\u003eAhmad Zulfikar, S.Pd. - Belajar Online\u003c/title\u003e\n    \n    \u003c!-- Tailwind CSS --\u003e\n    \u003cscript src\u003d\"https://cdn.tailwindcss.com\"\u003e\u003c/script\u003e\n    \n    \u003c!-- Font Awesome untuk Ikon --\u003e\n    \u003clink rel\u003d\"stylesheet\" href\u003d\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\"\u003e\n    \n    \u003c!-- Google Fonts --\u003e\n    \u003clink href\u003d\"https://fonts.googleapis.com/css2?family\u003dInter:wght@300;400;500;600\u0026family\u003dPlus+Jakarta+Sans:wght@500;600;700;800\u0026family\u003dAmiri:wght@400;700\u0026display\u003dswap\" rel\u003d\"stylesheet\"\u003e\n    \n    \u003cscript\u003e\n        tailwind.config \u003d {\n            theme: {\n                extend: {\n                    fontFamily: {\n                        sans: [\u0027Inter\u0027, \u0027sans-serif\u0027],\n                        heading: [\u0027Plus Jakarta Sans\u0027, \u0027sans-serif\u0027],\n                        arabic: [\u0027Amiri\u0027, \u0027serif\u0027],\n                    },\n                    colors: {\n                        teal: {\n                            850: \u0027#0f5d56\u0027,\n                            900: \u0027#134e4a\u0027,\n                            950: \u0027#042f2e\u0027,\n                        }\n                    }\n                }\n            }\n        }\n    \u003c/script\u003e\n    \n    \u003cstyle\u003e\n        body {\n            background-color: #f8fafc; /* Slate 50 */\n            color: #334155; /* Slate 700 */\n        }\n        \n        /* Custom Scrollbar */\n        ::-webkit-scrollbar { width: 8px; }\n        ::-webkit-scrollbar-track { background: #f1f5f9; }\n        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }\n        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }\n\n        /* Islamic Pattern Overlay */\n        .pattern-bg {\n            background-image: url(\"data:image/svg+xml,%3Csvg width\u003d\u002760\u0027 height\u003d\u002760\u0027 viewBox\u003d\u00270 0 60 60\u0027 xmlns\u003d\u0027http://www.w3.org/2000/svg\u0027%3E%3Cg fill\u003d\u0027none\u0027 fill-rule\u003d\u0027evenodd\u0027%3E%3Cg fill\u003d\u0027%23ffffff\u0027 fill-opacity\u003d\u00270.05\u0027%3E%3Cpath d\u003d\u0027M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\u0027/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n        }\n\n        /* Animations */\n        .fade-in {\n            animation: fadeIn 0.8s ease-out forwards;\n            opacity: 0;\n            transform: translateY(20px);\n        }\n        .delay-100 { animation-delay: 0.1s; }\n        .delay-200 { animation-delay: 0.2s; }\n        .delay-300 { animation-delay: 0.3s; }\n        .delay-400 { animation-delay: 0.4s; }\n\n        @keyframes fadeIn { \n            to { opacity: 1; transform: translateY(0); } \n        }\n\n        /* Card Hover Effects */\n        .menu-card, .hover-card {\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n        .menu-card:hover, .hover-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 12px 20px -8px rgba(0, 0, 0, 0.1);\n        }\n\n        .modal-backdrop {\n            background-color: rgba(15, 23, 42, 0.7);\n            backdrop-filter: blur(4px);\n            animation: fadeInModal 0.2s ease-out;\n        }\n        .modal-content {\n            animation: slideUp 0.3s ease-out;\n        }\n\n        @keyframes fadeInModal { from { opacity: 0; } to { opacity: 1; } }\n        @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }\n    \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody class\u003d\"font-sans antialiased selection:bg-teal-200 selection:text-teal-900 overflow-x-hidden flex flex-col min-h-screen\"\u003e\n\n    \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d NAVBAR \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n    \u003cnav class\u003d\"fixed w-full z-50 transition-all duration-300 bg-white/90 backdrop-blur-md border-b border-slate-200/50 shadow-sm\"\u003e\n        \u003cdiv class\u003d\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"\u003e\n            \u003cdiv class\u003d\"flex justify-between items-center h-16\"\u003e\n                \u003c!-- Logo/Brand --\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/\" target\u003d\"_top\" class\u003d\"flex items-center gap-3 hover:opacity-80 transition-opacity\"\u003e\n                    \u003cdiv class\u003d\"w-8 h-8 rounded-lg bg-teal-600 flex items-center justify-center text-white\"\u003e\n                        \u003ci class\u003d\"fa-solid fa-book-open text-sm\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                    \u003cspan class\u003d\"font-heading font-bold text-lg tracking-wide text-slate-800\"\u003eBelajar\u003cspan class\u003d\"text-teal-600\"\u003eOnline\u003c/span\u003e\u003c/span\u003e\n                \u003c/a\u003e\n\n                \u003c!-- Desktop Menu --\u003e\n                \u003cdiv class\u003d\"hidden md:flex items-center space-x-8\"\u003e\n                    \u003c!-- Menu Terpilih (Active) --\u003e\n                    \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/fiqih\" target\u003d\"_top\" class\u003d\"text-sm font-bold text-teal-600 relative after:content-[\u0027\u0027] after:absolute after:-bottom-1.5 after:left-0 after:w-full after:h-0.5 after:bg-teal-600 transition-colors\"\u003e\n                        Materi Fiqih\n                    \u003c/a\u003e\n                    \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/IPA\" target\u003d\"_top\" class\u003d\"text-sm font-medium text-slate-600 hover:text-teal-600 transition-colors\"\u003e\n                        Materi IPA\n                    \u003c/a\u003e\n                    \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/formatif\" target\u003d\"_top\" class\u003d\"text-sm font-medium text-slate-600 hover:text-teal-600 transition-colors\"\u003e\n                        Uji Kompetensi\n                    \u003c/a\u003e\n                    \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/nilai-siswa\" target\u003d\"_top\" class\u003d\"text-sm font-medium text-slate-600 hover:text-teal-600 transition-colors\"\u003e\n                        Rekap Nilai\n                    \u003c/a\u003e\n                \u003c/div\u003e\n\n                \u003c!-- Mobile Menu Button --\u003e\n                \u003cdiv class\u003d\"md:hidden flex items-center\"\u003e\n                    \u003cbutton onclick\u003d\"document.getElementById(\u0027mobile-menu\u0027).classList.toggle(\u0027hidden\u0027)\" class\u003d\"text-slate-600 hover:text-teal-600 focus:outline-none p-2\"\u003e\n                        \u003ci class\u003d\"fa-solid fa-bars text-xl\"\u003e\u003c/i\u003e\n                    \u003c/button\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n\n        \u003c!-- Mobile Menu (Hidden by default) --\u003e\n        \u003cdiv id\u003d\"mobile-menu\" class\u003d\"hidden md:hidden bg-white border-t border-slate-100 shadow-lg absolute w-full\"\u003e\n            \u003cdiv class\u003d\"px-4 pt-4 pb-6 space-y-2\"\u003e\n                \u003c!-- Menu Terpilih Mobile (Active) --\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/fiqih\" target\u003d\"_top\" class\u003d\"block px-4 py-3 rounded-md text-base font-bold text-teal-700 bg-teal-50 border-l-4 border-teal-600 transition-colors\"\u003eMateri Fiqih\u003c/a\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/IPA\" target\u003d\"_top\" class\u003d\"block px-4 py-3 rounded-md text-base font-medium text-slate-700 hover:text-teal-600 hover:bg-teal-50 transition-colors\"\u003eMateri IPA\u003c/a\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/formatif\" target\u003d\"_top\" class\u003d\"block px-4 py-3 rounded-md text-base font-medium text-slate-700 hover:text-teal-600 hover:bg-teal-50 transition-colors\"\u003eUji Kompetensi\u003c/a\u003e\n                \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/nilai-siswa\" target\u003d\"_top\" class\u003d\"block px-4 py-3 rounded-md text-base font-medium text-slate-700 hover:text-teal-600 hover:bg-teal-50 transition-colors\"\u003eRekap Nilai\u003c/a\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/nav\u003e\n\n    \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d HERO SECTION \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n\n        \u003c!-- Mobile Menu (Hidden by default) --\u003e\n        \u003cdiv id\u003d\"mobile-menu\" class\u003d\"hidden md:hidden bg-white border-t border-slate-100 shadow-lg absolute w-full\"\u003e\n            \u003cdiv class\u003d\"px-4 pt-2 pb-6 space-y-1\"\u003e\n                \u003ca href\u003d\"#beranda\" class\u003d\"block px-3 py-3 rounded-md text-base font-medium text-teal-600 bg-teal-50\"\u003eBeranda\u003c/a\u003e\n                \u003cdiv class\u003d\"px-3 py-2\"\u003e\n                    \u003cbutton onclick\u003d\"document.getElementById(\u0027mobile-elearning-dropdown\u0027).classList.toggle(\u0027hidden\u0027); this.querySelector(\u0027i.fa-chevron-down\u0027).classList.toggle(\u0027rotate-180\u0027);\" class\u003d\"flex justify-between items-center w-full text-left text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 mt-2 focus:outline-none\"\u003e\n                        \u003cspan\u003eE-Learning\u003c/span\u003e\n                        \u003ci class\u003d\"fa-solid fa-chevron-down transition-transform duration-300\"\u003e\u003c/i\u003e\n                    \u003c/button\u003e\n                    \u003cdiv id\u003d\"mobile-elearning-dropdown\" class\u003d\"hidden space-y-1 pl-2 mt-3 mb-2 border-l-2 border-slate-100 ml-1\"\u003e\n                        \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/fiqih\" target\u003d\"_top\" class\u003d\"block text-sm text-slate-600 py-2.5 pl-3 hover:text-teal-600 hover:bg-teal-50 rounded-r-md transition-colors\"\u003e\u003ci class\u003d\"fa-solid fa-mosque w-5 text-teal-500\"\u003e\u003c/i\u003e Materi Fiqih\u003c/a\u003e\n                        \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/IPA\" target\u003d\"_top\" class\u003d\"block text-sm text-slate-600 py-2.5 pl-3 hover:text-blue-600 hover:bg-blue-50 rounded-r-md transition-colors\"\u003e\u003ci class\u003d\"fa-solid fa-flask-vial w-5 text-blue-500\"\u003e\u003c/i\u003e Materi IPA\u003c/a\u003e\n                        \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/formatif\" target\u003d\"_top\" class\u003d\"block text-sm text-slate-600 py-2.5 pl-3 hover:text-amber-600 hover:bg-amber-50 rounded-r-md transition-colors\"\u003e\u003ci class\u003d\"fa-solid fa-file-pen w-5 text-amber-500\"\u003e\u003c/i\u003e Uji Kompetensi\u003c/a\u003e\n                        \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/nilai-siswa\" target\u003d\"_top\" class\u003d\"block text-sm text-slate-600 py-2.5 pl-3 hover:text-orange-600 hover:bg-orange-50 rounded-r-md transition-colors\"\u003e\u003ci class\u003d\"fa-solid fa-chart-pie w-5 text-orange-500\"\u003e\u003c/i\u003e Rekap Nilai\u003c/a\u003e\n                    \u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/nav\u003e\n\n    \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d HEADER / TOP SECTION \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n    \u003cheader class\u003d\"w-full bg-teal-900 relative pt-32 pb-24 overflow-hidden pattern-bg\"\u003e\n        \u003cdiv class\u003d\"absolute inset-0 bg-gradient-to-b from-transparent to-teal-900/90\"\u003e\u003c/div\u003e\n        \u003cdiv class\u003d\"container mx-auto px-6 relative z-10 max-w-4xl text-center fade-in\"\u003e\n            \u003cspan class\u003d\"inline-flex items-center gap-2 bg-teal-800/80 border border-teal-700 text-teal-100 px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase mb-6 shadow-sm\"\u003e\n                \u003ci class\u003d\"fa-solid fa-book-bookmark text-amber-400\"\u003e\u003c/i\u003e Materi Pembelajaran\n            \u003c/span\u003e\n            \u003ch2 class\u003d\"text-4xl md:text-5xl font-bold text-white mb-4 font-arabic\" dir\u003d\"rtl\"\u003eالفقه الإسلامي\u003c/h2\u003e\n            \u003ch3 class\u003d\"text-2xl md:text-3xl font-bold text-amber-400 mb-4 font-heading\"\u003eModul Pembelajaran Fiqih\u003c/h3\u003e\n            \u003cp class\u003d\"text-teal-100/90 text-sm md:text-base max-w-lg mx-auto leading-relaxed font-light mb-2\"\u003e\n                Pahami hukum Islam dengan mudah dan interaktif. Silakan pilih topik materi di bawah ini untuk memulai.\n            \u003c/p\u003e\n        \u003c/div\u003e\n    \u003c/header\u003e\n\n    \u003c!-- Main Content: Topic Grid --\u003e\n    \u003cmain id\u003d\"modul\" class\u003d\"flex-grow w-full max-w-5xl px-6 pb-16 -mt-10 mx-auto relative z-20\"\u003e\n        \u003cdiv class\u003d\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\"\u003e\n            \n            \u003c!-- Card 1: Shalat Jumat --\u003e\n            \u003cdiv onclick\u003d\"openSelectionModal()\" class\u003d\"cursor-pointer group fade-in delay-100 h-full\"\u003e\n                \u003cdiv class\u003d\"menu-card bg-white border border-slate-200 rounded-2xl p-6 h-full flex flex-col items-center text-center shadow-sm hover:shadow-md relative overflow-hidden\"\u003e\n                    \u003cdiv class\u003d\"w-14 h-14 bg-teal-50 rounded-xl flex items-center justify-center text-teal-600 mb-5 text-2xl group-hover:bg-teal-600 group-hover:text-white transition-all duration-300 shadow-sm border border-teal-100 group-hover:border-teal-600\"\u003e\n                        \u003ci class\u003d\"fas fa-users-viewfinder\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                    \u003ch3 class\u003d\"text-lg font-bold text-slate-800 mb-2 font-heading group-hover:text-teal-700 transition-colors\"\u003eShalat Jumat\u003c/h3\u003e\n                    \u003cp class\u003d\"text-xs text-slate-500 mb-6 leading-relaxed flex-grow\"\u003ePelajari tata cara Shalat Jumat dan panduan Khutbah yang benar.\u003c/p\u003e\n                    \n                    \u003cdiv class\u003d\"mt-auto w-full\"\u003e\n                        \u003cspan class\u003d\"flex items-center justify-center gap-2 w-full py-2.5 bg-slate-50 text-teal-700 text-xs font-semibold rounded-xl group-hover:bg-teal-50 border border-slate-100 group-hover:border-teal-200 transition-all\"\u003e\n                            Buka Materi \u003ci class\u003d\"fa-solid fa-arrow-right text-[10px]\"\u003e\u003c/i\u003e\n                        \u003c/span\u003e\n                    \u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003c!-- Card 2: Shalat Jama\u0027 \u0026 Qasar --\u003e\n            \u003cdiv onclick\u003d\"openJamaQasarModal()\" class\u003d\"cursor-pointer group fade-in delay-100 h-full\"\u003e\n                \u003cdiv class\u003d\"menu-card bg-white border border-slate-200 rounded-2xl p-6 h-full flex flex-col items-center text-center shadow-sm hover:shadow-md relative overflow-hidden\"\u003e\n                    \u003cdiv class\u003d\"w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 mb-5 text-2xl group-hover:bg-blue-600 group-hover:text-white transition-all duration-300 shadow-sm border border-blue-100 group-hover:border-blue-600\"\u003e\n                        \u003ci class\u003d\"fas fa-route\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                    \u003ch3 class\u003d\"text-lg font-bold text-slate-800 mb-2 font-heading group-hover:text-blue-700 transition-colors\"\u003eJama\u0027 \u0026 Qasar\u003c/h3\u003e\n                    \u003cp class\u003d\"text-xs text-slate-500 mb-6 leading-relaxed flex-grow\"\u003eKeringanan shalat bagi musafir dalam perjalanan jauh.\u003c/p\u003e\n                    \n                    \u003cdiv class\u003d\"mt-auto w-full\"\u003e\n                        \u003cspan class\u003d\"flex items-center justify-center gap-2 w-full py-2.5 bg-slate-50 text-blue-700 text-xs font-semibold rounded-xl group-hover:bg-blue-50 border border-slate-100 group-hover:border-blue-200 transition-all\"\u003e\n                            Buka Materi \u003ci class\u003d\"fa-solid fa-arrow-right text-[10px]\"\u003e\u003c/i\u003e\n                        \u003c/span\u003e\n                    \u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003c!-- Card 3: Kondisi Darurat --\u003e\n            \u003cdiv onclick\u003d\"openDaruratModal()\" class\u003d\"cursor-pointer group fade-in delay-200 h-full\"\u003e\n                \u003cdiv class\u003d\"menu-card bg-white border border-slate-200 rounded-2xl p-6 h-full flex flex-col items-center text-center shadow-sm hover:shadow-md relative overflow-hidden\"\u003e\n                    \u003cdiv class\u003d\"w-14 h-14 bg-amber-50 rounded-xl flex items-center justify-center text-amber-600 mb-5 text-2xl group-hover:bg-amber-500 group-hover:text-white transition-all duration-300 shadow-sm border border-amber-100 group-hover:border-amber-500\"\u003e\n                        \u003ci class\u003d\"fas fa-wheelchair\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                    \u003ch3 class\u003d\"text-lg font-bold text-slate-800 mb-2 font-heading group-hover:text-amber-700 transition-colors\"\u003eKondisi Khusus\u003c/h3\u003e\n                    \u003cp class\u003d\"text-xs text-slate-500 mb-6 leading-relaxed flex-grow\"\u003ePanduan shalat saat sakit dan di kendaraan.\u003c/p\u003e\n                    \n                    \u003cdiv class\u003d\"mt-auto w-full\"\u003e\n                        \u003cspan class\u003d\"flex items-center justify-center gap-2 w-full py-2.5 bg-slate-50 text-amber-700 text-xs font-semibold rounded-xl group-hover:bg-amber-50 border border-slate-100 group-hover:border-amber-200 transition-all\"\u003e\n                            Buka Materi \u003ci class\u003d\"fa-solid fa-arrow-right text-[10px]\"\u003e\u003c/i\u003e\n                        \u003c/sp