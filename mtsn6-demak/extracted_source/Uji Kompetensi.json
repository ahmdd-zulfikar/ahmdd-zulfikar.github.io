kar.github.io/mtsn6-demak/formatif\" target\u003d\"_top\" class\u003d\"block px-3 py-3 rounded-md text-base font-bold text-teal-700 bg-teal-50 border-l-4 border-teal-600 transition-colors\"\u003eUji Kompetensi\u003c/a\u003e\n                \u003c/div\u003e\n\n                \u003c!-- Standalone Links Mobile --\u003e\n                \u003cdiv class\u003d\"px-2 mt-1\"\u003e\n                    \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/nilai-siswa\" target\u003d\"_top\" class\u003d\"block px-3 py-3 rounded-md text-base font-medium text-slate-700 hover:text-teal-600 hover:bg-slate-50 transition-colors\"\u003eRekap Nilai\u003c/a\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/nav\u003e\n\n    \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d MAIN CONTENT \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n    \u003cmain class\u003d\"flex-grow w-full max-w-2xl px-4 pt-32 pb-12 flex flex-col items-center relative z-10\"\u003e\n\n        \u003c!-- Status Bar --\u003e\n        \u003cdiv class\u003d\"w-full flex items-center justify-between mb-6 px-2\"\u003e\n            \u003cdiv\u003e\n                \u003cp class\u003d\"text-[11px] text-slate-500 font-bold uppercase tracking-widest\"\u003eWaktu Sistem\u003c/p\u003e\n                \u003cp class\u003d\"text-sm font-bold text-slate-700\" id\u003d\"clock\"\u003e00:00 WIB\u003c/p\u003e\n            \u003c/div\u003e\n            \u003cdiv class\u003d\"text-right\"\u003e\n                \u003cp class\u003d\"text-[11px] text-slate-500 font-bold uppercase tracking-widest\"\u003eStatus Server\u003c/p\u003e\n                \u003cp class\u003d\"text-sm font-bold text-teal-600 flex items-center justify-end\"\u003e\n                    \u003cspan class\u003d\"w-2 h-2 bg-teal-500 rounded-full mr-2 animate-pulse\"\u003e\u003c/span\u003e Online\n                \u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n\n        \u003c!-- Token Section (Common in Exam Apps) --\u003e\n        \u003cdiv class\u003d\"glass-card w-full rounded-3xl p-8 md:p-10 mb-6 text-center border-t-4 border-teal-600 animate-fade-in relative overflow-hidden bg-white/90\"\u003e\n            \u003c!-- Background Icon --\u003e\n            \u003cdiv class\u003d\"absolute -top-6 -right-6 p-4 opacity-5 transform rotate-12 pointer-events-none\"\u003e\n                \u003ci class\u003d\"fa-solid fa-book-open text-9xl text-teal-600\"\u003e\u003c/i\u003e\n            \u003c/div\u003e\n            \n            \u003c!-- Logo Belajar Online Center --\u003e\n            \u003cp class\u003d\"text-slate-500 text-sm mb-6 leading-relaxed relative z-10\"\u003eMasukkan Token Ujian yang diberikan oleh Guru Mapel Anda untuk memulai asesmen formatif.\u003c/p\u003e\n            \n            \u003cdiv class\u003d\"flex flex-col sm:flex-row gap-4 justify-center items-stretch w-full max-w-md mx-auto relative z-10\"\u003e\n                \u003cinput type\u003d\"text\" id\u003d\"tokenInput\" placeholder\u003d\"KODE TOKEN\" class\u003d\"w-full px-5 py-4 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 text-center uppercase tracking-[0.2em] font-bold text-slate-800 shadow-inner bg-slate-50 transition-all placeholder:text-slate-400 placeholder:tracking-normal placeholder:font-medium\"\u003e\n                \u003cbutton onclick\u003d\"validateToken()\" class\u003d\"w-full sm:w-auto bg-teal-600 hover:bg-teal-700 text-white px-8 py-4 rounded-xl font-bold transition-colors shadow-md shadow-teal-600/20 flex items-center justify-center gap-2 whitespace-nowrap\"\u003e\n                    Masuk \u003ci class\u003d\"fa-solid fa-arrow-right-to-bracket\"\u003e\u003c/i\u003e\n                \u003c/button\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n\n    \u003c/main\u003e\n\n    \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d FOOTER \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n    \u003cfooter class\u003d\"w-full bg-teal-950 text-teal-200 py-10 border-t border-teal-900 mt-auto relative z-10\"\u003e\n        \u003cdiv class\u003d\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center\"\u003e\n            \u003ca href\u003d\"https://ahmdd-zulfikar.github.io/mtsn6-demak/\" target\u003d\"_top\" class\u003d\"inline-flex items-center justify-center gap-3 mb-4 text-white hover:opacity-80 transition-opacity\"\u003e\n                \u003ci class\u003d\"fa-solid fa-book-open text-xl text-teal-500\"\u003e\u003c/i\u003e\n                \u003cspan class\u003d\"font-heading font-bold text-xl tracking-wide\"\u003eBelajar\u003cspan class\u003d\"text-teal-500\"\u003eOnline\u003c/span\u003e\u003c/span\u003e\n            \u003c/a\u003e\n            \u003cp class\u003d\"text-sm text-teal-400/80 max-w-md mx-auto mb-8\"\u003e\n                Belajar Online adalah Sistem Pembelajaran Berbasis Digital untuk Memudahkan Guru dan Murid dalam Mencapai Tujuan Pembelajaran.\n            \u003c/p\u003e\n            \u003cdiv class\u003d\"pt-6 border-t border-teal-900/50 text-xs text-teal-500\"\u003e\n                \u003cp\u003e\u0026copy; 2026 Ahmad Zulfikar, S.Pd.\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/footer\u003e\n\n    \u003c!-- JavaScript Logic --\u003e\n    \u003cscript\u003e\n        // \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n        // KONFIGURASI TOKEN \u0026 LINK UJIAN (EDIT DI SINI)\n        // \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n        // Format: \u0027TOKEN\u0027: { url: \u0027LINK_TUJUAN\u0027, mapel: \u0027NAMA_MAPEL\u0027 }\n        const databaseUjian \u003d {\n            \u0027AFFQHSJ\u0027: { \n                url: \u0027https://mtsn6-demak.github.io/formatif/shalat-jumat\u0027, \n                mapel: \u0027Fikih : Shalat Jumat\u0027 \n            },\n            \u0027AFIPAGGC\u0027: { \n                url: \u0027https://mtsn6-demak.github.io/formatif/getaran-gelombang-cahaya\u0027, \n                mapel: \u0027IPA: Getaran, Gelombang, dan Cahaya\u0027 \n            },\n            \u0027PTSIPA8\u0027: { \n                url: \u0027https://google.com\u0027, // Contoh link lain\n                mapel: \u0027PTS IPA Kelas 8\u0027 \n            }\n            // Tambahkan baris baru di bawah ini untuk token lainnya...\n        };\n        // \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n\n        // Clock functionality\n        function updateClock() {\n            const now \u003d new Date();\n            const hours \u003d String(now.getHours()).padStart(2, \u00270\u0027);\n            const minutes \u003d String(now.getMinutes()).padStart(2, \u00270\u0027);\n            document.getElementById(\u0027clock\u0027).innerText \u003d `${hours}:${minutes} WIB`;\n        }\n        setInterval(updateClock, 1000);\n        updateClock();\n\n        // Token Validation Logic\n        function validateToken() {\n            const inputToken \u003d document.getElementById(\u0027tokenInput\u0027).value.trim().toUpperCase();\n            \n            if(!inputToken) {\n                Swal.fire({\n                    icon: \u0027warning\u0027,\n                    title: \u0027Token Kosong\u0027,\n                    text: \u0027Silakan masukkan Token Ujian terlebih dahulu!\u0027,\n                    confirmButtonColor: \u0027#0d9488\u0027\n                });\n                return;\n            }\n\n            if (databaseUjian.hasOwnProperty(inputToken)) {\n                const dataUjian \u003d databaseUjian[inputToken];\n                \n                Swal.fire({\n                    icon: \u0027success\u0027,\n                    title: \u0027Akses Diterima\u0027,\n                    html: `Membuka Evaluasi:\u003cbr\u003e\u003cb class\u003d\"text-teal-700 mt-2 block\"\u003e${dataUjian.mapel}\u003c/b\u003e`,\n                    timer: 2000,\n                    showConfirmButton: false,\n                    willClose: () \u003d\u003e {\n                        window.location.href \u003d dataUjian.url;\n                    }\n                });\n            } else {\n                Swal.fire({\n                    icon: \u0027error\u0027,\n                    title: \u0027Token Tidak Valid\u0027,\n                    text: \u0027Pastikan kode token yang Anda masukkan benar dan sesuai dari guru pengampu.\u0027,\n                    confirmButtonColor: \u0027#ef4444\u0027\n                });\n            }\n        }\n    \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e"}]}