{"files":[{"id":"0d717baf-2789-4870-adc5-4565934f7345","name":"appsscript","type":"json","source":"{\n  \"timeZone\": \"Asia/Jakarta\",\n  \"dependencies\": {},\n  \"exceptionLogging\": \"STACKDRIVER\",\n  \"runtimeVersion\": \"V8\",\n  \"webapp\": {\n    \"executeAs\": \"USER_DEPLOYING\",\n    \"access\": \"ANYONE_ANONYMOUS\"\n  }\n}"},{"id":"c0321047-7e93-4e90-ad00-c9876bd3c500","name":"Kode","type":"server_js","source":"function doGet() {\n  return HtmlService.createHtmlOutputFromFile(\u0027Index\u0027)\n    .setTitle(\u0027Portofolio Ahmad Zulfikar, S.Pd\u0027)\n    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);\n}"},{"id":"aa319423-191f-4c19-892b-5768711c83a7","name":"Index","type":"html","source":"\u003c!DOCTYPE html\u003e\n\u003chtml lang\u003d\"id\"\u003e\n\u003chead\u003e\n    \u003cmeta charset\u003d\"UTF-8\"\u003e\n    \u003cmeta name\u003d\"viewport\" content\u003d\"width\u003ddevice-width, initial-scale\u003d1.0\"\u003e\n    \u003ctitle\u003eProfil Ahmad Zulfikar\u003c/title\u003e\n    \n    \u003c!-- Tailwind CSS --\u003e\n    \u003cscript src\u003d\"https://cdn.tailwindcss.com\"\u003e\u003c/script\u003e\n    \n    \u003c!-- Font Awesome untuk Ikon --\u003e\n    \u003clink rel\u003d\"stylesheet\" href\u003d\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\"\u003e\n    \n    \u003c!-- Google Fonts --\u003e\n    \u003clink href\u003d\"https://fonts.googleapis.com/css2?family\u003dInter:wght@300;400;500;600\u0026family\u003dPlus+Jakarta+Sans:wght@500;600;700;800\u0026family\u003dAmiri:wght@400;700\u0026display\u003dswap\" rel\u003d\"stylesheet\"\u003e\n    \n    \u003cscript\u003e\n        tailwind.config \u003d {\n            theme: {\n                extend: {\n                    fontFamily: {\n                        sans: [\u0027Inter\u0027, \u0027sans-serif\u0027],\n                        heading: [\u0027Plus Jakarta Sans\u0027, \u0027sans-serif\u0027],\n                        arabic: [\u0027Amiri\u0027, \u0027serif\u0027],\n                    },\n                    colors: {\n                        teal: {\n                            850: \u0027#0f5d56\u0027,\n                            900: \u0027#134e4a\u0027,\n                            950: \u0027#042f2e\u0027,\n                        }\n                    }\n                }\n            }\n        }\n    \u003c/script\u003e\n    \n    \u003cstyle\u003e\n        body {\n            background-color: #f1f5f9; /* Slate 100 */\n            color: #334155;\n        }\n        \n        /* Custom Scrollbar */\n        ::-webkit-scrollbar { width: 6px; }\n        ::-webkit-scrollbar-track { background: transparent; }\n        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }\n        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }\n\n        /* Islamic Pattern Overlay */\n        .pattern-bg {\n            background-image: url(\"data:image/svg+xml,%3Csvg width\u003d\u002760\u0027 height\u003d\u002760\u0027 viewBox\u003d\u00270 0 60 60\u0027 xmlns\u003d\u0027http://www.w3.org/2000/svg\u0027%3E%3Cg fill\u003d\u0027none\u0027 fill-rule\u003d\u0027evenodd\u0027%3E%3Cg fill\u003d\u0027%23ffffff\u0027 fill-opacity\u003d\u00270.05\u0027%3E%3Cpath d\u003d\u0027M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\u0027/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n        }\n\n        /* Animations */\n        .fade-in {\n            animation: fadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;\n            opacity: 0;\n            transform: translateY(20px);\n        }\n        .delay-100 { animation-delay: 0.1s; }\n        .delay-200 { animation-delay: 0.2s; }\n        .delay-300 { animation-delay: 0.3s; }\n        .delay-400 { animation-delay: 0.4s; }\n        .delay-500 { animation-delay: 0.5s; }\n\n        @keyframes fadeIn { \n            to { opacity: 1; transform: translateY(0); } \n        }\n\n        /* Card Hover */\n        .menu-card {\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n        .menu-card:hover {\n            transform: translateY(-4px) scale(1.01);\n            border-color: #14b8a6; /* Teal 500 */\n            box-shadow: 0 10px 25px -5px rgba(20, 184, 166, 0.15), 0 8px 10px -6px rgba(20, 184, 166, 0.1);\n        }\n        \n        .glass-effect {\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(10px);\n            -webkit-backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n    \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody class\u003d\"min-h-screen flex items-center justify-center font-sans antialiased selection:bg-teal-200 selection:text-teal-900 p-4 md:p-8 lg:p-12\"\u003e\n\n    \u003c!-- Main Container: Responsive Width (Max 1024px) --\u003e\n    \u003cmain class\u003d\"w-full max-w-5xl bg-white min-h-[90vh] md:min-h-[80vh] rounded-3xl md:rounded-[2.5rem] shadow-2xl relative flex flex-col md:flex-row overflow-hidden border border-slate-200/60 fade-in\"\u003e\n        \n        \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d LEFT PANEL (PROFILE) \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n        \u003csection class\u003d\"relative w-full md:w-5/12 bg-teal-900 pattern-bg flex flex-col items-center justify-center p-8 md:p-12 text-center shrink-0\"\u003e\n            \u003c!-- Gradient Overlay --\u003e\n            \u003cdiv class\u003d\"absolute inset-0 bg-gradient-to-b from-teal-850/80 to-teal-950/95\"\u003e\u003c/div\u003e\n            \n            \u003c!-- Decorative Elements --\u003e\n            \u003cdiv class\u003d\"absolute inset-0 overflow-hidden\"\u003e\n                \u003cdiv class\u003d\"absolute -top-20 -left-20 w-64 h-64 bg-teal-500 opacity-20 rounded-full blur-3xl\"\u003e\u003c/div\u003e\n                \u003cdiv class\u003d\"absolute bottom-10 -right-10 w-48 h-48 bg-amber-400 opacity-10 rounded-full blur-2xl\"\u003e\u003c/div\u003e\n            \u003c/div\u003e\n            \n            \u003c!-- Content --\u003e\n            \u003cdiv class\u003d\"relative z-10 flex flex-col items-center w-full\"\u003e\n                \u003c!-- Bismillah Text --\u003e\n                \u003cp class\u003d\"font-arabic text-2xl text-teal-100/90 mb-8 fade-in delay-100 tracking-wider\"\u003eبِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ\u003c/p\u003e\n                \n                \u003c!-- Profile Photo --\u003e\n                \u003cdiv class\u003d\"relative group fade-in delay-200 mb-6\"\u003e\n                    \u003cdiv class\u003d\"absolute -inset-2 bg-gradient-to-tr from-amber-400 to-teal-300 rounded-full blur-md opacity-40 group-hover:opacity-75 transition duration-500 animate-pulse\"\u003e\u003c/div\u003e\n                    \u003cimg src\u003d\"https://github.com/ahmdd-zulfikar/ahmdd-zulfikar.github.io/blob/main/foto-profil.jpg?raw\u003dtrue\" \n                         alt\u003d\"Foto Profil Ahmad Zulfikar\" \n                         onerror\u003d\"this.src\u003d\u0027https://ui-avatars.com/api/?name\u003dAhmad+Zulfikar\u0026background\u003d0d9488\u0026color\u003dfff\u0026size\u003d200\u0027\"\n                         class\u003d\"relative w-36 h-36 md:w-44 md:h-44 rounded-full border-4 border-white shadow-2xl object-cover bg-white transition-transform duration-500 group-hover:scale-105\"\u003e\n                    \n                    \u003c!-- Status Badge --\u003e\n                    \u003cdiv class\u003d\"absolute bottom-2 right-2 w-8 h-8 bg-amber-500 border-2 border-white rounded-full flex items-center justify-center shadow-lg transform hover:rotate-12 transition-transform\" title\u003d\"Aktif Mengajar\"\u003e\n                        \u003ci class\u003d\"fa-solid fa-graduation-cap text-white text-xs\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                \u003c/div\u003e\n\n                \u003c!-- Name \u0026 Title --\u003e\n                \u003cdiv class\u003d\"fade-in delay-300\"\u003e\n                    \u003ch1 class\u003d\"text-3xl md:text-4xl font-extrabold text-white tracking-tight font-heading mb-2\"\u003eAhmad Zulfikar\u003cspan class\u003d\"text-xl md:text-2xl font-semibold text-teal-200\"\u003e, S.Pd\u003c/span\u003e\u003c/h1\u003e\n                    \n                    \u003cdiv class\u003d\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass-effect text-teal-50 text-sm font-medium mb-6\"\u003e\n                        \u003ci class\u003d\"fa-solid fa-book-open text-teal-300\"\u003e\u003c/i\u003e\n                        \u003cspan\u003ePendidik\u003c/span\u003e\n                    \u003c/div\u003e\n                    \n                    \u003cdiv class\u003d\"relative\"\u003e\n                        \u003ci class\u003d\"fa-solid fa-quote-left text-teal-700/50 text-3xl absolute -top-2 -left-4\"\u003e\u003c/i\u003e\n                        \u003cp class\u003d\"text-sm md:text-base text-teal-100/90 leading-relaxed font-light max-w-[280px] mx-auto italic px-4\"\u003e\n                            \"Sebaik-baik manusia adalah yang paling bermanfaat bagi manusia lainnya.\"\n                        \u003c/p\u003e\n                        \u003ci class\u003d\"fa-solid fa-quote-right text-teal-700/50 text-3xl absolute -bottom-2 -right-2\"\u003e\u003c/i\u003e\n                    \u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n            \n            \u003c!-- Social/Contact Icons (Optional Add-on) --\u003e\n            \u003cdiv class\u003d\"relative z-10 flex gap-4 mt-10 fade-in delay-400\"\u003e\n                \u003ca href\u003d\"https://wa.me/6285888892326\" target\u003d\"_blank\" rel\u003d\"noopener noreferrer\" class\u003d\"w-10 h-10 rounded-full glass-effect flex items-center justify-center text-white hover:bg-white hover:text-teal-900 transition-all shadow-lg\" title\u003d\"Hubungi via WhatsApp\"\u003e\n                    \u003ci class\u003d\"fa-brands fa-whatsapp text-lg\"\u003e\u003c/i\u003e\n                \u003c/a\u003e\n                \u003ca href\u003d\"mailto:ahmadzulfikar600@gmail.com\" class\u003d\"w-10 h-10 rounded-full glass-effect flex items-center justify-center text-white hover:bg-white hover:text-teal-900 transition-all shadow-lg\" title\u003d\"Kirim Email\"\u003e\n                    \u003ci class\u003d\"fa-regular fa-envelope text-lg\"\u003e\u003c/i\u003e\n                \u003c/a\u003e\n            \u003c/div\u003e\n        \u003c/section\u003e\n\n        \u003c!-- \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d RIGHT PANEL (LINKS) \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d --\u003e\n        \u003csection class\u003d\"w-full md:w-7/12 bg-slate-50 flex flex-col p-6 sm:p-8 md:p-12 lg:p-14 overflow-y-auto\"\u003e\n            \n            \u003c!-- Section Title --\u003e\n            \u003cdiv class\u003d\"mb-8 fade-in delay-200\"\u003e\n                \u003ch2 class\u003d\"text-xl md:text-2xl font-bold text-slate-800 font-heading\"\u003ePortofolio\u003c/h2\u003e\n                \u003cdiv class\u003d\"h-1 w-12 bg-teal-500 rounded-full mt-2\"\u003e\u003c/div\u003e\n                \u003cp class\u003d\"text-sm text-slate-500 mt-3\"\u003eRekam jejak pengabdian dalam dunia pendidikan.\u003c/p\u003e\n            \u003c/div\u003e\n\n            \u003c!-- Menu Container --\u003e\n            \u003cdiv class\u003d\"space-y-4 md:space-y-5 flex-1\"\u003e\n                \n                \u003c!-- Menu 1: PPTQ At-Tibyan Laren --\u003e\n                \u003ca href\u003d\"javascript:void(0)\" onclick\u003d\"showModal(\u0027attibyan\u0027)\" class\u003d\"group block w-full fade-in delay-300\"\u003e\n                    \u003cdiv class\u003d\"menu-card relative flex items-center p-4 md:p-5 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden\"\u003e\n                        \u003cdiv class\u003d\"absolute inset-0 bg-gradient-to-r from-teal-50/50 to-transparent translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500 ease-out\"\u003e\u003c/div\u003e\n                        \n                        \u003c!-- Icon/Logo --\u003e\n                        \u003cdiv class\u003d\"relative w-14 h-14 md:w-16 md:h-16 flex-shrink-0 bg-white border border-slate-100 rounded-xl flex items-center justify-center shadow-sm p-2 z-10 group-hover:border-teal-200 transition-colors\"\u003e\n                            \u003cimg src\u003d\"https://github.com/ahmdd-zulfikar/ahmdd-zulfikar.github.io/blob/main/logo-pptq.png?raw\u003dtrue\" \n                                 onerror\u003d\"this.style.display\u003d\u0027none\u0027; this.nextElementSibling.style.display\u003d\u0027block\u0027;\"\n                                 alt\u003d\"Logo PPTQ At-Tibyan\" \n                                 class\u003d\"w-full h-full object-contain group-hover:scale-110 transition-transform duration-300\"\u003e\n                            \u003c!-- Fallback Icon if Image Fails --\u003e\n                            \u003ci class\u003d\"fa-solid fa-mosque text-teal-600 text-xl hidden\"\u003e\u003c/i\u003e\n                        \u003c/div\u003e\n                        \n                        \u003c!-- Text --\u003e\n                        \u003cdiv class\u003d\"relative ml-4 md:ml-5 flex-1\"\u003e\n                            \u003ch3 class\u003d\"font-bold text-base md:text-lg text-slate-800 font-heading group-hover:text-teal-700 transition-colors\"\u003ePPTQ At-Tibyan Laren\u003c/h3\u003e\n                        \u003c/div\u003e\n                        \n                        \u003c!-- Arrow --\u003e\n                        \u003cdiv class\u003d\"relative text-slate-300 group-hover:text-teal-500