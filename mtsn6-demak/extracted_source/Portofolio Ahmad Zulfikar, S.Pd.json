0027;\"\n                                 alt\u003d\"Logo MTsN 6 Demak\" \n                                 class\u003d\"w-full h-full object-contain group-hover:scale-110 transition-transform duration-300\"\u003e\n                             \u003ci class\u003d\"fa-solid fa-school text-teal-600 text-xl hidden\"\u003e\u003c/i\u003e\n                        \u003c/div\u003e\n                        \n                        \u003cdiv class\u003d\"relative ml-4 md:ml-5 flex-1\"\u003e\n                            \u003ch3 class\u003d\"font-bold text-base md:text-lg text-slate-800 font-heading group-hover:text-teal-700 transition-colors\"\u003eMTsN 6 Demak\u003c/h3\u003e\n                        \u003c/div\u003e\n                        \n                        \u003cdiv class\u003d\"relative text-slate-300 group-hover:text-teal-500 transition-colors duration-300 transform translate-x-2 group-hover:translate-x-0 w-8 flex justify-end\"\u003e\n                            \u003ci class\u003d\"fa-solid fa-arrow-right-long text-lg\"\u003e\u003c/i\u003e\n                        \u003c/div\u003e\n                    \u003c/div\u003e\n                \u003c/a\u003e\n\n                \u003c!-- Menu 4: MTSS Al-Ishlah Laren --\u003e\n                \u003ca href\u003d\"javascript:void(0)\" onclick\u003d\"showModal(\u0027alishlah\u0027)\" class\u003d\"group block w-full fade-in delay-500\"\u003e\n                    \u003cdiv class\u003d\"menu-card relative flex items-center p-4 md:p-5 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden\"\u003e\n                        \u003cdiv class\u003d\"absolute inset-0 bg-gradient-to-r from-teal-50/50 to-transparent translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500 ease-out\"\u003e\u003c/div\u003e\n                        \n                        \u003c!-- Icon/Logo --\u003e\n                        \u003cdiv class\u003d\"relative w-14 h-14 md:w-16 md:h-16 flex-shrink-0 bg-white border border-slate-100 rounded-xl flex items-center justify-center shadow-sm p-2 z-10 group-hover:border-teal-200 transition-colors\"\u003e\n                            \u003cimg src\u003d\"https://github.com/ahmdd-zulfikar/ahmdd-zulfikar.github.io/blob/main/logo-alishlah.png?raw\u003dtrue\" \n                                 onerror\u003d\"this.style.display\u003d\u0027none\u0027; this.nextElementSibling.style.display\u003d\u0027block\u0027;\"\n                                 alt\u003d\"Logo MTSS Al-Ishlah Laren\" \n                                 class\u003d\"w-full h-full object-contain group-hover:scale-110 transition-transform duration-300\"\u003e\n                             \u003ci class\u003d\"fa-solid fa-school text-teal-600 text-xl hidden\"\u003e\u003c/i\u003e\n                        \u003c/div\u003e\n                        \n                        \u003cdiv class\u003d\"relative ml-4 md:ml-5 flex-1\"\u003e\n                            \u003ch3 class\u003d\"font-bold text-base md:text-lg text-slate-800 font-heading group-hover:text-teal-700 transition-colors\"\u003eMTSS Al-Ishlah Laren\u003c/h3\u003e\n                        \u003c/div\u003e\n                        \n                        \u003cdiv class\u003d\"relative text-slate-300 group-hover:text-teal-500 transition-colors duration-300 transform translate-x-2 group-hover:translate-x-0 w-8 flex justify-end\"\u003e\n                            \u003ci class\u003d\"fa-solid fa-arrow-right-long text-lg\"\u003e\u003c/i\u003e\n                        \u003c/div\u003e\n                    \u003c/div\u003e\n                \u003c/a\u003e\n\n            \u003c/div\u003e\n\n        \u003c/section\u003e\n\n    \u003c/main\u003e\n\n    \u003c!-- Modal Popup Kelembagaan --\u003e\n    \u003cdiv id\u003d\"inst-modal\" class\u003d\"fixed inset-0 z-[100] hidden items-center justify-center p-4\"\u003e\n        \u003c!-- Backdrop --\u003e\n        \u003cdiv class\u003d\"absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity\" onclick\u003d\"closeModal()\"\u003e\u003c/div\u003e\n        \n        \u003c!-- Modal Content --\u003e\n        \u003cdiv class\u003d\"relative bg-white w-full max-w-sm md:max-w-md rounded-3xl shadow-2xl p-6 md:p-8 transform scale-95 opacity-0 transition-all duration-300 flex flex-col\" id\u003d\"inst-modal-content\"\u003e\n            \u003c!-- Close Button --\u003e\n            \u003cbutton onclick\u003d\"closeModal()\" class\u003d\"absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 text-slate-500 hover:bg-red-50 hover:text-red-500 transition-colors focus:outline-none\"\u003e\n                \u003ci class\u003d\"fa-solid fa-xmark\"\u003e\u003c/i\u003e\n            \u003c/button\u003e\n            \n            \u003ch3 id\u003d\"inst-title\" class\u003d\"text-xl md:text-2xl font-bold text-slate-800 font-heading text-center mb-6 px-4\"\u003eNama Lembaga\u003c/h3\u003e\n            \n            \u003cdiv id\u003d\"inst-links\" class\u003d\"flex flex-col gap-3\"\u003e\n                \u003c!-- Tautan akan diisi melalui JavaScript --\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003c!-- Skrip Logika Popup --\u003e\n    \u003cscript\u003e\n        const institutions \u003d {\n            \u0027attibyan\u0027: {\n                name: \u0027PPTQ At-Tibyan Laren\u0027,\n                links: [\n                    { label: \u0027Instagram\u0027, icon: \u0027fa-brands fa-instagram\u0027, url: \u0027https://www.instagram.com/pptq_attibyan_laren/\u0027, color: \u0027text-pink-600\u0027 },\n                    { label: \u0027TikTok\u0027, icon: \u0027fa-brands fa-tiktok\u0027, url: null, color: \u0027text-slate-800\u0027 },\n                    { label: \u0027YouTube\u0027, icon: \u0027fa-brands fa-youtube\u0027, url: null, color: \u0027text-red-600\u0027 },\n                    { label: \u0027Website\u0027, icon: \u0027fa-solid fa-globe\u0027, url: null, color: \u0027text-blue-600\u0027 },\n                    { label: \u0027Belajar Online\u0027, icon: \u0027fa-solid fa-book-open\u0027, url: null, color: \u0027text-teal-600\u0027 }\n                ]\n            },\n            \u0027man2brebes\u0027: {\n                name: \u0027MAN 2 Brebes\u0027,\n                links: [\n                    { label: \u0027Instagram\u0027, icon: \u0027fa-brands fa-instagram\u0027, url: \u0027https://www.instagram.com/man2brebes/\u0027, color: \u0027text-pink-600\u0027 },\n                    { label: \u0027TikTok\u0027, icon: \u0027fa-brands fa-tiktok\u0027, url: \u0027https://www.tiktok.com/@man2brebes\u0027, color: \u0027text-slate-800\u0027 },\n                    { label: \u0027YouTube\u0027, icon: \u0027fa-brands fa-youtube\u0027, url: \u0027https://www.youtube.com/@man2brebes\u0027, color: \u0027text-red-600\u0027 },\n                    { label: \u0027Website\u0027, icon: \u0027fa-solid fa-globe\u0027, url: \u0027https://www.man2brebes.sch.id/\u0027, color: \u0027text-blue-600\u0027 },\n                    { label: \u0027Belajar Online\u0027, icon: \u0027fa-solid fa-book-open\u0027, url: null, color: \u0027text-teal-600\u0027 }\n                ]\n            },\n            \u0027mtsn6demak\u0027: {\n                name: \u0027MTsN 6 Demak\u0027,\n                links: [\n                    { label: \u0027Instagram\u0027, icon: \u0027fa-brands fa-instagram\u0027, url: \u0027https://www.instagram.com/mtsnegeri6demak/\u0027, color: \u0027text-pink-600\u0027 },\n                    { label: \u0027TikTok\u0027, icon: \u0027fa-brands fa-tiktok\u0027, url: \u0027https://www.tiktok.com/@mtsn6demak\u0027, color: \u0027text-slate-800\u0027 },\n                    { label: \u0027YouTube\u0027, icon: \u0027fa-brands fa-youtube\u0027, url: \u0027https://www.youtube.com/@mtsn6demakchannel\u0027, color: \u0027text-red-600\u0027 },\n                    { label: \u0027Website\u0027, icon: \u0027fa-solid fa-globe\u0027, url: \u0027https://mtsn6demak.sch.id/\u0027, color: \u0027text-blue-600\u0027 },\n                    { label: \u0027Belajar Online\u0027, icon: \u0027fa-solid fa-book-open\u0027, url: \u0027https://ahmdd-zulfikar.github.io/mtsn6-demak/\u0027, color: \u0027text-teal-600\u0027 }\n                ]\n            },\n            \u0027alishlah\u0027: {\n                name: \u0027MTSS Al-Ishlah Laren\u0027,\n                links: [\n                    { label: \u0027Instagram\u0027, icon: \u0027fa-brands fa-instagram\u0027, url: \u0027https://www.instagram.com/mtsalishlahlaren/\u0027, color: \u0027text-pink-600\u0027 },\n                    { label: \u0027TikTok\u0027, icon: \u0027fa-brands fa-tiktok\u0027, url: \u0027https://www.tiktok.com/@mts.alishlah3\u0027, color: \u0027text-slate-800\u0027 },\n                    { label: \u0027YouTube\u0027, icon: \u0027fa-brands fa-youtube\u0027, url: \u0027https://www.youtube.com/@mts.al-ishlah6760\u0027, color: \u0027text-red-600\u0027 },\n                    { label: \u0027Website\u0027, icon: \u0027fa-solid fa-globe\u0027, url: \u0027https://mtsalislahlaren.sch.id/web/\u0027, color: \u0027text-blue-600\u0027 },\n                    { label: \u0027Belajar Online\u0027, icon: \u0027fa-solid fa-book-open\u0027, url: null, color: \u0027text-teal-600\u0027 }\n                ]\n            }\n        };\n\n        function showModal(id) {\n            const data \u003d institutions[id];\n            if(!data) return;\n            \n            document.getElementById(\u0027inst-title\u0027).textContent \u003d data.name;\n            \n            const linksContainer \u003d document.getElementById(\u0027inst-links\u0027);\n            linksContainer.innerHTML \u003d \u0027\u0027;\n            \n            data.links.forEach(link \u003d\u003e {\n                if(link.url) {\n                    // Tautan yang tersedia\n                    linksContainer.innerHTML +\u003d `\n                        \u003ca href\u003d\"${link.url}\" target\u003d\"_blank\" rel\u003d\"noopener noreferrer\" class\u003d\"flex items-center gap-4 p-3 rounded-xl bg-slate-50 hover:bg-teal-50 border border-slate-100 hover:border-teal-200 transition-all group\"\u003e\n                            \u003cdiv class\u003d\"w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform ${link.color}\"\u003e\n                                \u003ci class\u003d\"${link.icon} text-lg\"\u003e\u003c/i\u003e\n                            \u003c/div\u003e\n                            \u003cspan class\u003d\"font-semibold text-slate-700 group-hover:text-teal-800 flex-1\"\u003e${link.label}\u003c/span\u003e\n                            \u003ci class\u003d\"fa-solid fa-arrow-up-right-from-square text-slate-300 group-hover:text-teal-500 text-sm\"\u003e\u003c/i\u003e\n                        \u003c/a\u003e\n                    `;\n                } else {\n                    // Tautan yang belum tersedia (terkunci)\n                    linksContainer.innerHTML +\u003d `\n                        \u003cdiv class\u003d\"flex items-center gap-4 p-3 rounded-xl bg-slate-50/40 border border-slate-100/50 cursor-not-allowed select-none\"\u003e\n                            \u003cdiv class\u003d\"w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-300\"\u003e\n                                \u003ci class\u003d\"${link.icon} text-lg\"\u003e\u003c/i\u003e\n                            \u003c/div\u003e\n                            \u003cdiv class\u003d\"flex-1 flex flex-col\"\u003e\n                                \u003cspan class\u003d\"font-semibold text-slate-400\"\u003e${link.label}\u003c/span\u003e\n                                \u003cspan class\u003d\"text-[10px] text-slate-400/80 font-medium italic\"\u003eBelum Tersedia\u003c/span\u003e\n                            \u003c/div\u003e\n                            \u003ci class\u003d\"fa-solid fa-lock text-slate-200 text-xs\"\u003e\u003c/i\u003e\n                        \u003c/div\u003e\n                    `;\n                }\n            });\n            \n            const modal \u003d document.getElementById(\u0027inst-modal\u0027);\n            const content \u003d document.getElementById(\u0027inst-modal-content\u0027);\n            \n            modal.classList.remove(\u0027hidden\u0027);\n            modal.classList.add(\u0027flex\u0027);\n            \n            // Animasi membesar (pop in)\n            setTimeout(() \u003d\u003e {\n                content.classList.remove(\u0027scale-95\u0027, \u0027opacity-0\u0027);\n                content.classList.add(\u0027scale-100\u0027, \u0027opacity-100\u0027);\n            }, 10);\n        }\n\n        function closeModal() {\n            const modal \u003d document.getElementById(\u0027inst-modal\u0027);\n            const content \u003d document.getElementById(\u0027inst-modal-content\u0027);\n            \n            // Animasi mengecil (pop out)\n            content.classList.remove(\u0027scale-100\u0027, \u0027opacity-100\u0027);\n            content.classList.add(\u0027scale-95\u0027, \u0027opacity-0\u0027);\n            \n            setTimeout(() \u003d\u003e {\n                modal.classList.add(\u0027hidden\u0027);\n                modal.classList.remove(\u0027flex\u0027);\n            }, 300); // Sinkron dengan durasi CSS transition\n        }\n    \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e"}]}